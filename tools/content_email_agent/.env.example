# Copy this file to .env and fill values.
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.3-codex

# LLM backend: openai or ollama
LLM_BACKEND=ollama
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=600

# Email sender account (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=

# Inbox account for reading your feedback emails (IMAP)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=

# Workflow
OWNER_EMAIL=jeevan@fm-lead.com
HUGO_SITE_PATH=C:/Hugo/bin/fmlead
ARTICLE_ROOT_RELATIVE=content/focus/articles
FOCUS_FOLDER_NAME=focus
ARTICLE_SECTION_NAME=articles
DEFAULT_TAGS=focus mindset,leadership,execution
POLL_SECONDS=30

# Image generation for published article bundles
IMAGE_MODEL=gpt-image-1
IMAGE_SIZE=1536x1024
IMAGE_QUALITY=high
IMAGE_STYLE=natural
IMAGE_PROVIDER=unsplash
IMAGE_QUERY_MODE=source
# Optional extra art direction text appended to the image prompt
IMAGE_PROMPT_SUFFIX=
# Generate a second in-article image (detail-1.png)
GENERATE_DETAIL_IMAGE=true
IN_POST_IMAGE_COUNT=2
# Disable image generation for local-only workflows
GENERATE_IMAGES=true

# Source ingestion limits
MAX_SOURCE_CHARS=12000
ENABLE_URL_FETCH=true
TRACKER_FILENAME=fmlead_post_tracker.xlsx

# Daily topic approvals
DAILY_TOPICS_ENABLED=true
DAILY_TOPICS_COUNT=3
DAILY_TOPICS_HOUR_24=9
IDEA_PIPELINE_MAX=10

# Weekly reminder for unanswered topic approvals
WEEKLY_IDEA_REMINDER_ENABLED=true
# Monday=0 ... Sunday=6
WEEKLY_REMINDER_DAY_0_MON=0
WEEKLY_REMINDER_HOUR_24=9

# Attach generated images in draft/revision emails
ATTACH_IMAGES_IN_DRAFT_EMAIL=true

# Approval-email image mapping block (always appended to topic/draft/revision emails)
IMAGE_THUMB_FILENAME=THUMB_test.jpg
IMAGE_BODY1_FILENAME=BODY1_test.jpg
IMAGE_BODY2_FILENAME=BODY2_test.jpg
